# Server
PORT=3000
NODE_ENV=development

# Database (MSSQL)
DATABASE_URL=sqlserver://localhost:1433;database=acr;user=sa;password=YourPassword123
MSSQL_SA_PASSWORD=YourPassword123

# JWT
JWT_SECRET=your-random-32-char-secret-here
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Redis
REDIS_URL=redis://localhost:6379

# AWS (LocalStack for local dev)
AWS_REGION=ap-southeast-1
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET_ATTACHMENTS=acr-attachments-dev
SES_FROM_EMAIL=no-reply@dits.co.th

# Frontend
FRONTEND_URL=http://localhost:5173

# Upload
MAX_FILE_SIZE_MB=10
