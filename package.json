{
  "name": "acr-management-system",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "ACR Management System — ระบบบริหารจัดการคำขอเปลี่ยนแปลง/แก้ไขสิทธิและระบบสารสนเทศ",
  "scripts": {
    "dev": "pnpm --parallel --filter './packages/*' dev",
    "build": "pnpm --filter './packages/*' build",
    "lint": "eslint 'packages/*/src/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'packages/*/src/**/*.{ts,tsx}' --fix",
    "test": "pnpm --filter './packages/*' test",
    "format": "prettier --write 'packages/*/src/**/*.{ts,tsx,json,css}'",
    "format:check": "prettier --check 'packages/*/src/**/*.{ts,tsx,json,css}'"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.6",
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
